# Copy to .env or set in your shell / Compose — keys only, never commit real tokens.
# NFR12: no live credentials in this file; match docker-compose.yml and application*.yml binding.
#
# --- Docker Compose (story 7.2 / FR32): app + db + llm ---
# Requires Docker Compose v2 (`docker compose` subcommand).
#
# Story 7.4: `POSTGRES_USER`, `POSTGRES_PASSWORD`, and `POSTGRES_DB` default to **examinai** in
# `docker-compose.yml` when unset, so the DB role and app JDBC user stay aligned. Prefer setting
# these three together; do not rely on implicit DB users (Postgres has no `root` login).
#
# POSTGRES_USER=examinai
# POSTGRES_PASSWORD=examinai
# POSTGRES_DB=examinai
# Optional host port overrides (defaults: 5432 / 8080 / 11434):
# POSTGRES_PUBLISH_PORT=5432
# APP_PUBLISH_PORT=8080
# OLLAMA_PUBLISH_PORT=11434
# Pin/replace LLM image (compose default: ollama/ollama:0.20.2):
# OLLAMA_IMAGE=ollama/ollama:0.20.2
#
# App JDBC / AI (defaults suit the bundled compose file — db host service name `db`, llm `llm`):
# SPRING_PROFILES_ACTIVE=dev
# SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/examinai
# SPRING_DATASOURCE_USERNAME=examinai
# SPRING_DATASOURCE_PASSWORD=examinai
# OLLAMA_BASE_URL=http://llm:11434
# Model name for Spring AI and for automatic `ollama pull` inside the llm container (see docker-compose entrypoint).
# OLLAMA_MODEL=deepseek-r1:8b

# --- Production / pilot JDBC aliases (application-prod.yml) ---
# Same JDBC as SPRING_DATASOURCE_* ; use when deploy templates prefer DATABASE_* names:
# DATABASE_URL=jdbc:postgresql://localhost:5432/examinai
# DATABASE_USERNAME=examinai
# DATABASE_PASSWORD=

# --- Git provider (story 3.1): GitHub REST v3–compatible API root; token only via env / secret store ---
GIT_PROVIDER_BASE_URL=https://api.github.com
GIT_PROVIDER_TOKEN=

# Optional tuning (story 3.2 — bounded retries / timeouts)
# GIT_READ_TIMEOUT_SECONDS=22
# GIT_MAX_RETRIES=2
# GIT_RETRY_BACKOFF_MS=350

# --- Optional Examinai feature toggles & AI bounds (application.yml examinai.*) ---
# EXAMINAI_INTERN_SHOW_AI_DRAFT=true
# EXAMINAI_LLM_HEALTH_PROBE_ENABLED=false
# EXAMINAI_LLM_HEALTH_CONNECT_TIMEOUT_MS=2000
# EXAMINAI_LLM_HEALTH_READ_TIMEOUT_MS=3000
# EXAMINAI_AI_DRAFT_MAX_SOURCE_CHARS=100000
# EXAMINAI_AI_DRAFT_TIMEOUT_SECONDS=90
# EXAMINAI_AI_DRAFT_MAX_RETRIES=2
# EXAMINAI_AI_DRAFT_RETRY_BACKOFF_MS=400
# EXAMINAI_AI_DRAFT_MAX_INFERENCE_WALL_SECONDS=300
# EXAMINAI_AI_DRAFT_MAX_FLASH_CHARS=32768
# EXAMINAI_AI_AUDIT_MODEL_VERSION=
