# Copy to .env and fill in locally (never commit .env). Spring Boot maps these when exported or via tooling.

# Primary (Spring Boot relaxed names)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/examinai
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# Alternative names still accepted in application-prod.yml
# DATABASE_URL=
# DATABASE_USERNAME=
# DATABASE_PASSWORD=

# Optional
# OLLAMA_BASE_URL=http://127.0.0.1:11434
