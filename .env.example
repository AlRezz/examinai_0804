# Copy to .env or set in your shell / Compose — keys only, never commit real tokens.
#
# --- Docker Compose (story 7.2 / FR32): app + db + llm ---
# Requires Docker Compose v2 (`docker compose` subcommand).
#
# POSTGRES_USER=examinai
# POSTGRES_PASSWORD=examinai
# POSTGRES_DB=examinai
# Optional host port overrides (defaults: 5432 / 8080 / 11434):
# POSTGRES_PUBLISH_PORT=5432
# APP_PUBLISH_PORT=8080
# OLLAMA_PUBLISH_PORT=11434
#
# App JDBC / AI (defaults suit the bundled compose file — db host service name `db`, llm `llm`):
# SPRING_PROFILES_ACTIVE=dev
# SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/examinai
# SPRING_DATASOURCE_USERNAME=examinai
# SPRING_DATASOURCE_PASSWORD=examinai
# OLLAMA_BASE_URL=http://llm:11434
# OLLAMA_MODEL=llama3.2
#
# Git provider (GitHub REST v3-compatible API at base URL). Story 3.1 — config-only credentials.
GIT_PROVIDER_BASE_URL=https://api.github.com
GIT_PROVIDER_TOKEN=

# Optional tuning (Story 3.2 — bounded retries / timeouts)
# GIT_READ_TIMEOUT_SECONDS=22
# GIT_MAX_RETRIES=2
# GIT_RETRY_BACKOFF_MS=350
